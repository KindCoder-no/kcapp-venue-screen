# Kcapp Venue Screen - Environment Variables Example

# API Configuration
# Base URL for API calls (should be relative to the app host)
VITE_KCAPP_API_BASE=http://localhost:3000/api

# Socket.IO connection URL for live scoring
VITE_KCAPP_SOCKET_URL=http://localhost

# Venue list endpoint
VITE_KCAPP_VENUE_LIST_URL=http://localhost:3000/api/venues

# Optional: Basic Authentication (leave empty if not needed)
VITE_KCAPP_BASIC_AUTH_USERNAME=
VITE_KCAPP_BASIC_AUTH_PASSWORD=

# Optional: Deploy app under a subpath (example: /screen)
# Leave as / for root deployment
VITE_APP_BASE_PATH=/
